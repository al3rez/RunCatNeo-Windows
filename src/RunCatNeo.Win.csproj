<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>RunCatNeo.Win</RootNamespace>
    <AssemblyName>RunCatNeo</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
    <InvariantGlobalization>true</InvariantGlobalization>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Version>1.0.0</Version>
    <Product>RunCat Neo for Windows</Product>
    <Description>A cute running cat animation in your Windows system tray, paced by CPU usage. Unofficial Windows port of RunCat Neo.</Description>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources\Runners\*.png" LogicalName="runners/%(Filename)%(Extension)" />
  </ItemGroup>

</Project>
